# Required: Steam Web API key for GetPlayerItems (dupe detection needs original_id)
# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_from_https_steamcommunity_com_dev_apikey

# Required: Redis connection URL for server-side caching (6h TTL) and rate limiting
# Multi-instance deployments need Redis for shared cache
REDIS_URL=redis://localhost:6379

# Optional: GitHub repo URL for footer link (e.g. https://github.com/owner/repo)
# NEXT_PUBLIC_REPO_URL=
