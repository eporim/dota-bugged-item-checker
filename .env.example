# If self-hosting, use this for NextJS (if not, use the default from the Dockerfile):
env HOSTNAME=0.0.0.0 PORT=3000 node .next/standalone/server.js

# Required: Steam Web API key for GetPlayerItems (dupe detection needs original_id)
# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key

# Required: Redis connection URL for server-side caching (6h TTL) and rate limiting
# Multi-instance deployments need Redis for shared cache
REDIS_URL=redis://default:your_password@localhost:6379

# Deploy Supabase via Dokploy template, then add these env vars
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Dokploy CI/CD with GitHub Actions
DOKPLOY_AUTH_TOKEN=YOUR_API_TOKEN
DOKPLOY_APPLICATION_ID=YOUR_APPLICATION_ID
DOKPLOY_URL=YOUR_DOKPLOY_URL